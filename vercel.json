{
  "version": 2,
  "name": "designer-paper",
  "routes": [
    {
      "src": "/thenew",
      "dest": "/landing-thenew/index.html"
    },
    {
      "src": "/pluma",
      "dest": "/landing-pluma/index.html"
    },
    {
      "src": "/templatemonster",
      "dest": "/landing-templatemonster/index.html"
    },
    {
      "src": "/thenew/(.*)",
      "dest": "/landing-thenew/$1"
    },
    {
      "src": "/pluma/(.*)",
      "dest": "/landing-pluma/$1"
    },
    {
      "src": "/templatemonster/(.*)",
      "dest": "/landing-templatemonster/$1"
    },
    {
      "src": "/",
      "dest": "/landing-thenew/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|woff2?|ttf|otf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
